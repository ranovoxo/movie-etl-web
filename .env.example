# Required in production. Keep this server-side only.
DATABASE_URL=postgresql://report_user:strong_password@your-rds-endpoint:5432/movie_db?sslmode=require

# Optional: set to false if your RDS connection does not require TLS.
PGSSL=true

# Optional: public label shown in the dashboard status area.
NEXT_PUBLIC_PIPELINE_LABEL=AWS EC2 Airflow

# Optional: external backend API base URL. Leave empty for local Next.js API routes.
NEXT_PUBLIC_REPORTS_API_URL=https://example.execute-api.us-east-1.amazonaws.com
